        "created",
        "command",
        "fallback_command",
        "message"
      ],
      "properties": {
        "attempted": { "const": true },
        "created": { "type": "boolean" },
        "url": { "type": "string" },
        "command": { "type": "string" },
        "fallback_command": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "quickstartReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["directory", "workspace_root", "initialized", "steps", "docs"],
      "properties": {
        "directory": { "type": "string" },
        "workspace_root": { "$ref": "#/$defs/nullableString" },
        "initialized": { "type": "boolean" },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/quickstartStep" }
        },
        "docs": {
          "type": "array",
          "items": { "$ref": "#/$defs/quickstartDoc" }
        }
      }
    },
    "quickstartStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "commands", "purpose"],
      "properties": {
        "title": { "type": "string" },
        "commands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "purpose": { "type": "string" }
      }
    },
    "quickstartDoc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "path"],
      "properties": {
        "title": { "type": "string" },
        "path": { "type": "string" }
      }
    },
    "raceLaneResults": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fork",
          "path",
          "exit_code",
          "duration_ms",
          "files_changed",
          "insertions",
          "deletions",
          "log_file"
        ],
        "properties": {
          "rank": { "$ref": "#/$defs/u64" },
          "fork": { "type": "string" },
          "label": { "type": "string" },
          "path": { "type": "string" },
          "exit_code": { "$ref": "#/$defs/nullableI32" },
          "duration_ms": { "$ref": "#/$defs/u64" },
          "attempts": { "$ref": "#/$defs/u64" },
          "timed_out": { "type": "boolean" },
          "canceled": { "type": "boolean" },
          "tests": { "$ref": "#/$defs/testSummary" },
          "files_changed": { "$ref": "#/$defs/u64" },
          "insertions": { "$ref": "#/$defs/u64" },
          "deletions": { "$ref": "#/$defs/u64" },
          "review": { "$ref": "#/$defs/forkReviewSignals" },
          "log_file": { "type": "string" }
        }
      }
    },
    "testSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reports",
        "tests",
        "failures",
        "errors",
        "skipped",
        "time_seconds"
      ],
      "properties": {
        "reports": { "$ref": "#/$defs/u64" },
        "tests": { "$ref": "#/$defs/u64" },
        "failures": { "$ref": "#/$defs/u64" },
        "errors": { "$ref": "#/$defs/u64" },
        "skipped": { "$ref": "#/$defs/u64" },
        "time_seconds": { "type": "number" }
      }
    },
    "retentionPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dry_run",
        "policy",
        "total_checkpoints",
        "retain_count",
        "delete_count",
        "checkpoints"
      ],
      "properties": {
        "dry_run": { "const": true },
        "policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["keep_last", "max_age_days"],
          "properties": {
            "keep_last": { "$ref": "#/$defs/nullableU64" },
            "max_age_days": { "$ref": "#/$defs/nullableU64" }
          }
        },
        "total_checkpoints": { "$ref": "#/$defs/u64" },
        "retain_count": { "$ref": "#/$defs/u64" },
        "delete_count": { "$ref": "#/$defs/u64" },
        "checkpoints": {
          "type": "array",
          "items": { "$ref": "#/$defs/retentionPlanEntry" }
        }
      }
    },
    "retentionPlanEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seq",
        "commit",
        "ts",
        "message",
        "age_hours",
        "action",
        "reason"
      ],
      "properties": {
        "seq": { "$ref": "#/$defs/u64" },
        "commit": { "$ref": "#/$defs/gitOid" },
        "ts": {
          "anyOf": [
            { "$ref": "#/$defs/dateTime" },
            { "type": "null" }
          ]
        },
        "message": { "$ref": "#/$defs/nullableString" },
        "age_hours": { "$ref": "#/$defs/nullableI64" },
        "action": {
          "type": "string",
          "enum": ["retain", "delete"]
        },
        "reason": { "type": "string" }
      }
    },
    "restoreReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_seq",
        "target_commit",
        "safety_seq",
        "files_written",
        "files_deleted"
      ],
      "properties": {
        "target_seq": { "$ref": "#/$defs/u64" },
        "target_commit": { "$ref": "#/$defs/gitOid" },
        "safety_seq": { "$ref": "#/$defs/nullableU64" },
        "files_written": { "$ref": "#/$defs/u64" },
        "files_deleted": { "$ref": "#/$defs/u64" }
      }
    },
    "schemaReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asp_version", "schemas"],
      "properties": {
        "asp_version": { "type": "string" },
        "schemas": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "version", "kind", "path"],
            "properties": {
              "name": {
                "type": "string",
                "enum": [
                  "cli_json_envelope",
                  "result_payloads",
                  "mcp_tool_result",
                  "workspace_config_toml",
                  "workspace_policy_toml",
                  "on_disk_format"
                ]
              },
              "version": { "$ref": "#/$defs/u64" },
              "kind": {
                "type": "string",
                "enum": ["json_schema", "toml_schema_doc", "store_format"]
              },
              "path": { "type": "string" }
            }
          }
        }
      }
    },
    "reviewReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generated_at", "workspace", "forks", "markdown"],
      "properties": {
        "generated_at": { "$ref": "#/$defs/dateTime" },
        "workspace": { "$ref": "#/$defs/statusReport" },
        "forks": { "$ref": "#/$defs/forkCompareRows" },
        "markdown": { "type": "string" }
      }
    },
    "setupReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "settings_file",
        "mcp_file",
        "hooks_installed",
        "mcp_registered",
        "removed"
      ],
      "properties": {
        "settings_file": { "type": "string" },
        "mcp_file": {
          "anyOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "hooks_installed": { "type": "boolean" },
        "mcp_registered": { "type": "boolean" },
        "removed": { "type": "boolean" }
      }
    },
    "statusReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "workspace_id",
        "dirty_files",
        "untracked_files",
        "deleted_files",
        "last_checkpoint",
        "active_forks",
        "is_fork"
      ],
      "properties": {
        "root": { "type": "string" },
        "workspace_id": { "type": "string" },
        "dirty_files": { "$ref": "#/$defs/u64" },
        "untracked_files": { "$ref": "#/$defs/u64" },
        "deleted_files": { "$ref": "#/$defs/u64" },
        "last_checkpoint": { "$ref": "#/$defs/nullableLastCheckpoint" },
        "active_forks": { "$ref": "#/$defs/u64" },
        "is_fork": { "type": "boolean" }
      }
    },
    "statsReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "workspace_id",
        "checkpoints",
        "journal_entries",
        "forks_total",
        "forks_pending",
        "forks_active",
        "forks_promoted",
        "forks_discarded",
        "blobs",
        "blob_bytes",
        "store_bytes",
        "last_operation",
        "recent_operations"
      ],
      "properties": {
        "root": { "type": "string" },
        "workspace_id": { "type": "string" },
        "checkpoints": { "$ref": "#/$defs/u64" },
        "journal_entries": { "$ref": "#/$defs/u64" },
        "forks_total": { "$ref": "#/$defs/u64" },
        "forks_pending": { "$ref": "#/$defs/u64" },
        "forks_active": { "$ref": "#/$defs/u64" },
        "forks_promoted": { "$ref": "#/$defs/u64" },
        "forks_discarded": { "$ref": "#/$defs/u64" },
        "blobs": { "$ref": "#/$defs/u64" },
        "blob_bytes": { "$ref": "#/$defs/u64" },
        "store_bytes": { "$ref": "#/$defs/u64" },
        "last_operation": {
          "anyOf": [
            { "$ref": "#/$defs/statsOperation" },
            { "type": "null" }
          ]
        },
        "recent_operations": {
          "type": "array",
          "items": { "$ref": "#/$defs/statsOperation" }
        }
      }
    },
    "statsOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "op",
        "ts",
        "seq",
        "duration_ms",
        "files_changed",
        "message"
      ],
      "properties": {
        "op": { "$ref": "#/$defs/op" },
        "ts": { "$ref": "#/$defs/dateTime" },
        "seq": { "$ref": "#/$defs/nullableU64" },
        "duration_ms": { "$ref": "#/$defs/nullableU64" },
        "files_changed": { "$ref": "#/$defs/nullableU64" },
        "message": { "$ref": "#/$defs/nullableString" }
      }
    },
    "syncPushReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "remote",
        "workspace_id",
        "checkpoints",
        "git_objects_uploaded",
        "git_objects_present",
        "cas_blobs_uploaded",
        "cas_blobs_present",
        "refs_created",
        "refs_present",
        "refs_replaced"
      ],
      "properties": {
        "remote": { "type": "string" },
        "workspace_id": { "type": "string" },
        "checkpoints": { "$ref": "#/$defs/u64" },
        "git_objects_uploaded": { "$ref": "#/$defs/u64" },
        "git_objects_present": { "$ref": "#/$defs/u64" },
        "cas_blobs_uploaded": { "$ref": "#/$defs/u64" },
        "cas_blobs_present": { "$ref": "#/$defs/u64" },
        "refs_created": { "$ref": "#/$defs/u64" },
        "refs_present": { "$ref": "#/$defs/u64" },
        "refs_replaced": { "$ref": "#/$defs/u64" }
      }
    },
    "syncFetchReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "remote",
        "workspace_id",
        "refs_imported",
        "refs_present",
        "refs_conflicted",
        "git_objects_downloaded",
        "git_objects_present",
        "cas_blobs_downloaded",
        "cas_blobs_present",
        "head_updated",
        "head_seq",
        "conflicts"
      ],
      "properties": {
        "remote": { "type": "string" },
        "workspace_id": { "type": "string" },
        "refs_imported": { "$ref": "#/$defs/u64" },
        "refs_present": { "$ref": "#/$defs/u64" },
        "refs_conflicted": { "$ref": "#/$defs/u64" },
        "git_objects_downloaded": { "$ref": "#/$defs/u64" },
        "git_objects_present": { "$ref": "#/$defs/u64" },
        "cas_blobs_downloaded": { "$ref": "#/$defs/u64" },
        "cas_blobs_present": { "$ref": "#/$defs/u64" },
        "head_updated": { "type": "boolean" },
        "head_seq": { "$ref": "#/$defs/nullableU64" },
        "conflicts": {
          "type": "array",
          "items": { "$ref": "#/$defs/syncRefConflict" }
        }
      }
    },
    "syncRefConflict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "seq", "local", "remote", "hint"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["checkpoint_ref", "meta_ref"]
        },
        "seq": { "$ref": "#/$defs/u64" },
        "local": { "$ref": "#/$defs/nullableString" },
        "remote": { "$ref": "#/$defs/nullableString" },
        "hint": { "type": "string" }
      }
    },
    "lastCheckpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seq", "ts", "message"],
      "properties": {
        "seq": { "$ref": "#/$defs/u64" },
        "ts": { "$ref": "#/$defs/dateTime" },
        "message": { "$ref": "#/$defs/nullableString" }
      }
    },
    "nullableLastCheckpoint": {
      "anyOf": [
        { "$ref": "#/$defs/lastCheckpoint" },
        { "type": "null" }
      ]
    },
    "cloneMethod": {
      "type": "string",
      "enum": ["clonefile", "reflink", "copy"]
    },
    "forkStatus": {
      "type": "string",
      "enum": ["pending", "active", "promoted", "discarded"]
    },
    "preflightCheckId": {
      "type": "string",
      "enum": [
        "preflight.config",
        "preflight.policy",
        "preflight.doctor",
        "preflight.secrets"
      ]
    },
    "op": {
      "type": "string",
      "enum": ["init", "checkpoint", "fork", "restore", "undo", "promote", "discard"]
    },
    "severity": {
      "type": "string",
      "enum": ["error", "warning", "info"]
    },
    "source": {
      "type": "string",
      "enum": ["manual", "hook", "mcp", "race"]
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "gitOid": {
      "type": "string",
      "pattern": "^[0-9a-f]{4,64}$"
    },
    "nullableI32": {
      "anyOf": [
        { "type": "integer", "minimum": -2147483648, "maximum": 2147483647 },
        { "type": "null" }
      ]
    },
    "nullableBool": {
      "anyOf": [
        { "type": "boolean" },
        { "type": "null" }
      ]
    },
    "nullableI64": {
      "anyOf": [
        { "type": "integer", "minimum": -9223372036854775808, "maximum": 9223372036854775807 },
        { "type": "null" }
      ]
    },
    "nullableString": {
      "anyOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "nullableU64": {
      "anyOf": [
        { "$ref": "#/$defs/u64" },
        { "type": "null" }
      ]
    },
    "u64": {
      "type": "integer",
      "minimum": 0
    }
  }
}
