{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/ArnavBorkar/agentspaces/main/schemas/asp-result.schema.json",
  "title": "asp result payloads",
  "description": "Result payloads emitted as CLI envelope result values and MCP structuredContent values.",
  "anyOf": [
    { "$ref": "#/$defs/benchSelfReport" },
    { "$ref": "#/$defs/checkpointInfo" },
    { "$ref": "#/$defs/completionResult" },
    { "$ref": "#/$defs/configShowReport" },
    { "$ref": "#/$defs/codexSetupReport" },
    { "$ref": "#/$defs/diagnosticBundle" },
    { "$ref": "#/$defs/diagnosticsOutputResult" },
    { "$ref": "#/$defs/diffHtmlOutputResult" },
    { "$ref": "#/$defs/diffReport" },
    { "$ref": "#/$defs/diffTextReport" },
    { "$ref": "#/$defs/discardResult" },
    { "$ref": "#/$defs/evidenceOutputResult" },
    { "$ref": "#/$defs/evidenceReport" },
    { "$ref": "#/$defs/forkCompareRows" },
    { "$ref": "#/$defs/forkInfos" },
    { "$ref": "#/$defs/initResult" },
    { "$ref": "#/$defs/journalEntries" },
    { "$ref": "#/$defs/manpageResult" },
    { "$ref": "#/$defs/noChanges" },
    { "$ref": "#/$defs/opencodeSetupReport" },
    { "$ref": "#/$defs/policyValidateReport" },
    { "$ref": "#/$defs/preflightReport" },
    { "$ref": "#/$defs/promoteReport" },
    { "$ref": "#/$defs/quickstartReport" },
    { "$ref": "#/$defs/raceLaneResults" },
    { "$ref": "#/$defs/retentionPlan" },
    { "$ref": "#/$defs/restoreReport" },
    { "$ref": "#/$defs/reviewReport" },
    { "$ref": "#/$defs/schemaReport" },
    { "$ref": "#/$defs/secretScanReport" },
    { "$ref": "#/$defs/setupReport" },
    { "$ref": "#/$defs/statusReport" },
    { "$ref": "#/$defs/statsReport" },
    { "$ref": "#/$defs/syncFetchReport" },
    { "$ref": "#/$defs/syncPushReport" },
    { "$ref": "#/$defs/doctorFindings" }
  ],
  "$defs": {
    "benchSelfReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "platform",
        "filesystem",
        "capabilities",
        "recommendations",
        "probe_errors"
      ],
      "properties": {
        "path": { "type": "string" },
        "platform": {
          "type": "object",
          "additionalProperties": false,
          "required": ["os", "arch", "supported", "support_hint"],
          "properties": {
            "os": { "type": "string" },
            "arch": { "type": "string" },
            "supported": { "type": "boolean" },
            "support_hint": { "$ref": "#/$defs/nullableString" }
          }
        },
        "filesystem": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "case_sensitive",
            "symlinks",
            "hardlinks",
            "atomic_rename"
          ],
          "properties": {
            "kind": { "$ref": "#/$defs/nullableString" },
            "case_sensitive": { "type": "boolean" },
            "symlinks": { "type": "boolean" },
            "hardlinks": { "type": "boolean" },
            "atomic_rename": { "type": "boolean" }
          }
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "directory_clone_method",
            "copy_on_write_forks",
            "large_file_sidecar_cow",
            "same_volume_forks_required"
          ],
          "properties": {
            "directory_clone_method": {
              "anyOf": [{ "$ref": "#/$defs/cloneMethod" }, { "type": "null" }]
            },
            "copy_on_write_forks": { "type": "boolean" },
            "large_file_sidecar_cow": { "type": "boolean" },
            "same_volume_forks_required": { "type": "boolean" }
          }
        },
        "recommendations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "probe_errors": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "checkpointInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seq", "commit", "files_changed", "duration_ms", "message"],
      "properties": {
        "seq": { "$ref": "#/$defs/u64" },
        "commit": { "$ref": "#/$defs/gitOid" },
        "files_changed": { "$ref": "#/$defs/u64" },
        "duration_ms": { "$ref": "#/$defs/u64" },
        "message": { "type": "string" }
      }
    },
    "completionResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shell", "completion"],
      "properties": {
        "shell": { "type": "string" },
        "completion": { "type": "string" }
      }
    },
    "codexSetupReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["config_file", "user_scope", "mcp_registered", "removed"],
      "properties": {
        "config_file": { "type": "string" },
        "user_scope": { "type": "boolean" },
        "mcp_registered": { "type": "boolean" },
        "removed": { "type": "boolean" }
      }
    },
    "configShowReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "path",
        "exists",
        "valid",
        "config",
        "shadow_excludes",
        "blob_threshold_bytes"
      ],
      "properties": {
        "root": { "type": "string" },
        "path": { "type": "string" },
        "exists": { "type": "boolean" },
        "valid": { "const": true },
        "config": { "$ref": "#/$defs/workspaceConfig" },
        "shadow_excludes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blob_threshold_bytes": { "$ref": "#/$defs/u64" }
      }
    },
    "diagnosticBundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generated_at",
        "asp_version",
        "format_version",
        "redaction",
        "workspace",
        "status",
        "stats",
        "config",
        "forks",
        "doctor_findings",
        "recent_operations"
      ],
      "properties": {
        "generated_at": { "$ref": "#/$defs/dateTime" },
        "asp_version": { "type": "string" },
        "format_version": { "$ref": "#/$defs/u64" },
        "redaction": {
          "type": "object",
          "additionalProperties": false,
          "required": ["paths_redacted", "secrets_redacted", "notes"],
          "properties": {
            "paths_redacted": { "type": "boolean" },
            "secrets_redacted": { "type": "boolean" },
            "notes": { "type": "array", "items": { "type": "string" } }
          }
        },
        "workspace": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "root",
            "workspace_id",
            "is_fork",
            "parent_workspace_id",
            "parent_fork_name"
          ],
          "properties": {
            "root": { "type": "string" },
            "workspace_id": { "type": "string" },
            "is_fork": { "type": "boolean" },
            "parent_workspace_id": { "$ref": "#/$defs/nullableString" },
            "parent_fork_name": { "$ref": "#/$defs/nullableString" }
          }
        },
        "status": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "dirty_files",
            "untracked_files",
            "deleted_files",
            "active_forks",
            "last_checkpoint"
          ],
          "properties": {
            "dirty_files": { "$ref": "#/$defs/u64" },
            "untracked_files": { "$ref": "#/$defs/u64" },
            "deleted_files": { "$ref": "#/$defs/u64" },
            "active_forks": { "$ref": "#/$defs/u64" },
            "last_checkpoint": { "$ref": "#/$defs/nullableLastCheckpoint" }
          }
        },
        "stats": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "checkpoints",
            "journal_entries",
            "forks_total",
            "forks_pending",
            "forks_active",
            "forks_promoted",
            "forks_discarded",
            "blobs",
            "blob_bytes",
            "store_bytes"
          ],
          "properties": {
            "checkpoints": { "$ref": "#/$defs/u64" },
            "journal_entries": { "$ref": "#/$defs/u64" },
            "forks_total": { "$ref": "#/$defs/u64" },
            "forks_pending": { "$ref": "#/$defs/u64" },
            "forks_active": { "$ref": "#/$defs/u64" },
            "forks_promoted": { "$ref": "#/$defs/u64" },
            "forks_discarded": { "$ref": "#/$defs/u64" },
            "blobs": { "$ref": "#/$defs/u64" },
            "blob_bytes": { "$ref": "#/$defs/u64" },
            "store_bytes": { "$ref": "#/$defs/u64" }
          }
        },
        "config": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "blob_threshold_mb",
            "excludes_count",
            "extra_excludes_count"
          ],
          "properties": {
            "blob_threshold_mb": { "$ref": "#/$defs/u64" },
            "excludes_count": { "$ref": "#/$defs/u64" },
            "extra_excludes_count": { "$ref": "#/$defs/u64" }
          }
        },
        "forks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "status",
              "fork_point_seq",
              "path",
              "missing"
            ],
            "properties": {
              "name": { "type": "string" },
              "status": { "$ref": "#/$defs/forkStatus" },
              "fork_point_seq": { "$ref": "#/$defs/u64" },
              "path": { "type": "string" },
              "missing": { "type": "boolean" }
            }
          }
        },
        "doctor_findings": { "$ref": "#/$defs/doctorFindings" },
        "recent_operations": {
          "type": "array",
          "items": { "$ref": "#/$defs/statsOperation" }
        }
      }
    },
    "diagnosticsOutputResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "redacted", "bundle"],
      "properties": {
        "path": { "type": "string" },
        "redacted": { "type": "boolean" },
        "bundle": { "$ref": "#/$defs/diagnosticBundle" }
      }
    },
    "diffReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "summary", "rows"],
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "files",
            "insertions",
            "deletions",
            "by_path",
            "by_language",
            "by_change_type"
          ],
          "properties": {
            "files": { "$ref": "#/$defs/u64" },
            "insertions": { "$ref": "#/$defs/u64" },
            "deletions": { "$ref": "#/$defs/u64" },
            "by_path": {
              "type": "array",
              "items": { "$ref": "#/$defs/diffSummaryBucket" }
            },
            "by_language": {
              "type": "array",
              "items": { "$ref": "#/$defs/diffSummaryBucket" }
            },
            "by_change_type": {
              "type": "array",
              "items": { "$ref": "#/$defs/diffSummaryBucket" }
            }
          }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "status", "insertions", "deletions"],
            "properties": {
              "path": { "type": "string" },
              "status": { "type": "string", "minLength": 1 },
              "insertions": { "$ref": "#/$defs/nullableU64" },
              "deletions": { "$ref": "#/$defs/nullableU64" }
            }
          }
        }
      }
    },
    "diffSummaryBucket": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "files", "insertions", "deletions"],
      "properties": {
        "name": { "type": "string" },
        "files": { "$ref": "#/$defs/u64" },
        "insertions": { "$ref": "#/$defs/u64" },
        "deletions": { "$ref": "#/$defs/u64" }
      }
    },
    "diffTextReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "mode", "summary", "text"],
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "mode": {
          "type": "string",
          "enum": ["patch", "stat"]
        },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "files",
            "insertions",
            "deletions",
            "by_path",
            "by_language",
            "by_change_type"
          ],
          "properties": {
            "files": { "$ref": "#/$defs/u64" },
            "insertions": { "$ref": "#/$defs/u64" },
            "deletions": { "$ref": "#/$defs/u64" },
            "by_path": {
              "type": "array",
              "items": { "$ref": "#/$defs/diffSummaryBucket" }
            },
            "by_language": {
              "type": "array",
              "items": { "$ref": "#/$defs/diffSummaryBucket" }
            },
            "by_change_type": {
              "type": "array",
              "items": { "$ref": "#/$defs/diffSummaryBucket" }
            }
          }
        },
        "text": { "type": "string" }
      }
    },
    "diffHtmlOutputResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "summary", "path", "bytes"],
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "files",
            "insertions",
            "deletions",
            "by_path",
            "by_language",
            "by_change_type"
          ],
          "properties": {
            "files": { "$ref": "#/$defs/u64" },
            "insertions": { "$ref": "#/$defs/u64" },
            "deletions": { "$ref": "#/$defs/u64" },
            "by_path": {
              "type": "array",
              "items": { "$ref": "#/$defs/diffSummaryBucket" }
            },
            "by_language": {
              "type": "array",
              "items": { "$ref": "#/$defs/diffSummaryBucket" }
            },
            "by_change_type": {
              "type": "array",
              "items": { "$ref": "#/$defs/diffSummaryBucket" }
            }
          }
        },
        "path": { "type": "string" },
        "bytes": { "$ref": "#/$defs/u64" }
      }
    },
    "discardResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["discarded"],
      "properties": {
        "discarded": { "type": "string" }
      }
    },
    "doctorFindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "message", "cause", "next_action", "fixed"],
        "properties": {
          "severity": { "$ref": "#/$defs/severity" },
          "message": { "type": "string" },
          "cause": { "type": "string" },
          "next_action": { "type": "string" },
          "repair_plan": { "$ref": "#/$defs/doctorRepairPlan" },
          "fixed": { "type": "boolean" }
        }
      }
    },
    "doctorRepairPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation", "description", "command", "destructive"],
      "properties": {
        "operation": { "type": "string" },
        "description": { "type": "string" },
        "command": { "type": "string" },
        "destructive": { "type": "boolean" }
      }
    },
    "evidenceOutputResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "redacted", "packet"],
      "properties": {
        "path": { "type": "string" },
        "redacted": { "type": "boolean" },
        "packet": { "$ref": "#/$defs/evidenceReport" }
      }
    },
    "evidenceReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generated_at",
        "asp_version",
        "redaction",
        "diagnostics",
        "preflight",
        "schema",
        "recent_audit_events"
      ],
      "properties": {
        "generated_at": { "$ref": "#/$defs/dateTime" },
        "asp_version": { "type": "string" },
        "redaction": { "$ref": "#/$defs/evidenceRedaction" },
        "diagnostics": { "$ref": "#/$defs/diagnosticBundle" },
        "preflight": { "$ref": "#/$defs/evidencePreflightReport" },
        "schema": { "$ref": "#/$defs/schemaReport" },
        "recent_audit_events": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceAuditEvent" }
        }
      }
    },
    "evidenceRedaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "paths_redacted",
        "secrets_redacted",
        "audit_messages_included",
        "audit_details_included"
      ],
      "properties": {
        "paths_redacted": { "type": "boolean" },
        "secrets_redacted": { "type": "boolean" },
        "audit_messages_included": { "type": "boolean" },
        "audit_details_included": { "type": "boolean" }
      }
    },
    "evidencePreflightReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ready", "checks", "doctor_findings", "secret_findings"],
      "properties": {
        "ready": { "type": "boolean" },
        "checks": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidencePreflightCheck" }
        },
        "doctor_findings": { "$ref": "#/$defs/u64" },
        "secret_findings": { "$ref": "#/$defs/u64" }
      }
    },
    "evidencePreflightCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "ok", "summary", "runbook", "hint"],
      "properties": {
        "id": { "$ref": "#/$defs/preflightCheckId" },
        "name": { "type": "string" },
        "ok": { "type": "boolean" },
        "summary": { "type": "string" },
        "runbook": { "type": "string" },
        "hint": { "$ref": "#/$defs/nullableString" }
      }
    },
    "evidenceAuditEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "op",
        "ts",
        "seq",
        "source",
        "duration_ms",
        "files_changed"
      ],
      "properties": {
        "op": { "$ref": "#/$defs/op" },
        "ts": { "$ref": "#/$defs/dateTime" },
        "seq": { "$ref": "#/$defs/nullableU64" },
        "source": {
          "anyOf": [
            { "$ref": "#/$defs/source" },
            { "type": "null" }
          ]
        },
        "duration_ms": { "$ref": "#/$defs/nullableU64" },
        "files_changed": { "$ref": "#/$defs/nullableU64" }
      }
    },
    "forkCompareRows": {
      "type": "array",
      "items": { "$ref": "#/$defs/forkCompareRow" }
    },
    "forkCompareRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status",
        "fork_point_seq",
        "files_changed",
        "insertions",
        "deletions",
        "last_activity",
        "path",
        "missing"
      ],
      "properties": {
        "name": { "type": "string" },
        "status": { "$ref": "#/$defs/forkStatus" },
        "fork_point_seq": { "$ref": "#/$defs/u64" },
        "files_changed": { "$ref": "#/$defs/u64" },
        "insertions": { "$ref": "#/$defs/u64" },
        "deletions": { "$ref": "#/$defs/u64" },
        "review": { "$ref": "#/$defs/forkReviewSignals" },
        "last_activity": {
          "anyOf": [
            { "$ref": "#/$defs/dateTime" },
            { "type": "null" }
          ]
        },
        "path": { "type": "string" },
        "missing": { "type": "boolean" }
      }
    },
    "forkReviewSignals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tests_passed",
        "files_touched",
        "line_churn",
        "risk_score",
        "risk_markers"
      ],
      "properties": {
        "tests_passed": { "$ref": "#/$defs/nullableBool" },
        "files_touched": { "$ref": "#/$defs/u64" },
        "line_churn": { "$ref": "#/$defs/u64" },
        "risk_score": { "$ref": "#/$defs/u64" },
        "risk_markers": {
          "type": "array",
          "items": { "$ref": "#/$defs/forkRiskMarker" }
        }
      }
    },
    "forkRiskMarker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "severity", "path", "message"],
      "properties": {
        "kind": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "path": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "forkInfos": {
      "type": "array",
      "items": { "$ref": "#/$defs/forkInfo" }
    },
    "forkInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "path",
        "fork_point_seq",
        "method",
        "duration_ms"
      ],
      "properties": {
        "name": { "type": "string" },
        "path": { "type": "string" },
        "fork_point_seq": { "$ref": "#/$defs/u64" },
        "method": { "$ref": "#/$defs/cloneMethod" },
        "duration_ms": { "$ref": "#/$defs/u64" }
      }
    },
    "initResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root"],
      "properties": {
        "root": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "journalEntries": {
      "type": "array",
      "items": { "$ref": "#/$defs/journalEntry" }
    },
    "journalEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["v", "ts", "op"],
      "properties": {
        "v": { "const": 1 },
        "ts": { "$ref": "#/$defs/dateTime" },
        "op": { "$ref": "#/$defs/op" },
        "seq": { "$ref": "#/$defs/u64" },
        "commit": { "$ref": "#/$defs/gitOid" },
        "source": { "$ref": "#/$defs/source" },
        "session_id": { "type": "string" },
        "tool": { "type": "string" },
        "message": { "type": "string" },
        "files_changed": { "$ref": "#/$defs/u64" },
        "duration_ms": { "$ref": "#/$defs/u64" },
        "detail": true
      }
    },
    "manpageResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "manpage"],
      "properties": {
        "name": { "type": "string" },
        "manpage": { "type": "string" }
      }
    },
    "noChanges": {
      "type": "object",
      "additionalProperties": false,
      "required": ["no_changes"],
      "properties": {
        "no_changes": { "const": true },
        "message": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "opencodeSetupReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["config_file", "user_scope", "mcp_registered", "removed"],
      "properties": {
