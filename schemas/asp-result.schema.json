    "secretFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "line", "kind", "redacted"],
      "properties": {
        "path": { "type": "string" },
        "line": { "$ref": "#/$defs/u64" },
        "kind": { "type": "string" },
        "redacted": { "type": "string" }
      }
    },
    "workspacePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["forks", "checkpoints", "paths", "promote", "retention"],
      "properties": {
        "forks": {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_active"],
          "properties": {
            "max_active": { "$ref": "#/$defs/nullableU64" }
          }
        },
        "checkpoints": {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_age_hours"],
          "properties": {
            "max_age_hours": { "$ref": "#/$defs/nullableU64" }
          }
        },
        "paths": {
          "type": "object",
          "additionalProperties": false,
          "required": ["protected", "deny_checkpoint"],
          "properties": {
            "protected": {
              "type": "array",
              "items": { "type": "string" }
            },
            "deny_checkpoint": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "promote": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "require_clean_status",
            "require_checkpoint",
            "allowed_branch_prefixes"
          ],
          "properties": {
            "require_clean_status": { "type": "boolean" },
            "require_checkpoint": { "type": "boolean" },
            "allowed_branch_prefixes": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "retention": {
          "type": "object",
          "additionalProperties": false,
          "required": ["keep_last", "max_age_days"],
          "properties": {
            "keep_last": { "$ref": "#/$defs/nullableU64" },
            "max_age_days": { "$ref": "#/$defs/nullableU64" }
          }
        }
      }
    },
    "workspaceConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capture", "promote"],
      "properties": {
        "capture": {
          "type": "object",
          "additionalProperties": false,
          "required": ["excludes", "extra_excludes", "blob_threshold_mb"],
          "properties": {
            "excludes": {
              "type": "array",
              "items": { "type": "string" }
            },
            "extra_excludes": {
              "type": "array",
              "items": { "type": "string" }
            },
            "blob_threshold_mb": { "$ref": "#/$defs/u64" }
          }
        },
        "promote": {
          "type": "object",
          "additionalProperties": false,
          "required": ["branch_template"],
          "properties": {
            "branch_template": { "type": "string" }
          }
        }
      }
    },
    "promoteReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fork",
        "fork_path",
        "fork_retained",
        "branch",
        "commit",
        "cleanup_command"
      ],
      "properties": {
        "fork": { "type": "string" },
        "fork_path": { "type": "string" },
        "fork_retained": { "const": true },
        "branch": { "type": "string" },
        "commit": { "$ref": "#/$defs/gitOid" },
        "cleanup_command": { "type": "string" },
        "push": { "$ref": "#/$defs/promotePushReport" },
        "pr": { "$ref": "#/$defs/promotePrDraftReport" }
      }
    },
    "promotePushReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pushed", "remote", "branch", "refspec", "command"],
      "properties": {
        "pushed": { "const": true },
        "remote": { "type": "string" },
        "branch": { "type": "string" },
        "refspec": { "type": "string" },
        "command": { "type": "string" }
      }
